@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if("@QT_VERSION_MAJOR@" STREQUAL "6")
    find_dependency(Qt6 REQUIRED COMPONENTS Core)
elseif("@QT_VERSION_MAJOR@" STREQUAL "5")
    find_dependency(Qt5 REQUIRED COMPONENTS Core)
else()
    message(FATAL_ERROR "Unsupported Qt major version encoded in CoreTemplate package: @QT_VERSION_MAJOR@")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/CoreTemplateTargets.cmake")

check_required_components(CoreTemplate)
